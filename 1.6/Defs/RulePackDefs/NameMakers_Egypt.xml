<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <RulePackDef>
    <defName>NamerPersonEgypt</defName>
    <rulePack>
		<rulesStrings>
			<li>name->[NamesEgypt] of [NamesEgypt]</li>
			<li>name->[NamesEgypt] [NamesEgypt]</li>
			<li>name->[NamesEgypt] the [Numbers]</li>
			<li>name->[NamesEgypt] [Last]</li>
			<li>r_name->[NamesEgypt] [Last]</li>
			<li>name->[Last] [NamesEgypt]</li>
			<li>r_name->[Last] [NamesEgypt]</li>
			<li>r_name->[NamesEgypt] '[Last]' [NamesEgypt]</li>
			<li>name->[NamesEgypt] '[Last]' [NamesEgypt]</li>
			<li>name(p=0.2)->[NamesEgypt] '[Prenomen]' [NamesEgypt]</li>
			<li>name(p=0.2)->[NamesEgypt] '[Prenomen]' [Last]</li>
			<!--
			<li>r_name(p=3)->[FirstMale] [Last]</li>
			<li>r_name->[FirstMale] '[Prenomen]' [Last]</li>
			<li>r_name(p=3)->[FirstFemale] [Last]</li>
			<li>r_name->[FirstFemale] '[Prenomen]' [Last]</li>
			-->
					
			<li>Prenomen->Nisut</li>
			<li>Prenomen->Za</li>
			<li>Prenomen->Za-Netger</li>
			<li>Prenomen->Za-Nesut</li>
			<li>Prenomen->Nomarch</li>
			<li>Prenomen->Hi</li>
			<li>Prenomen->Hi-Nesut</li>
			<li>Prenomen->Hi-Netjer</li>
			<li>Prenomen->He of the Two Ladies</li>
			<li>Prenomen->Netjer</li>
		</rulesStrings>
			<rulesFiles>
				<li>FirstMale->Names/ODLS_Egypt_FirstMale</li>
				<li>FirstFemale->Names/ODLS_Egypt_FirstFemale</li>
				<li>Prenomen->Names/ODLS_Egypt_TitlePrenomen</li>
				<li>Last->Names/ODLS_Egypt_Last</li>
			</rulesFiles>
      <rulesRaw>
        <li Class="Rule_File">
          <keyword>Numbers</keyword>
          <path>Words/Foreign/Numbers</path>
        </li>
        <li Class="Rule_File">
          <keyword>NamesEgypt</keyword>
          <path>Words/Foreign/NamesEgypt</path>
        </li>
      </rulesRaw>
    </rulePack>
  </RulePackDef>
  <RulePackDef>
    <defName>NamerSettlementEgypt</defName>
    <rulePack>
      <rulesStrings>
        <li>name(p=2)->[NamesEgypt]</li>
		<li>name->[KemetSettlementUpper]</li>
		<li>name->[KemetSettlementLower]</li>
		<li>r_name->[KemetSettlementUpper]</li>
		<li>r_name->[KemetSettlementLower]</li>
 	  </rulesStrings>
	  <rulesFiles>
		<li>KemetSettlementUpper->Names/ODLS_Egypt_SettlementUpper</li>
		<li>KemetSettlementLower->Names/ODLS_Egypt_SettlementLower</li>
	  </rulesFiles>
      <rulesRaw>
        <li Class="Rule_File">
          <keyword>NamesEgypt</keyword>
          <path>Words/Foreign/NamesEgypt</path>
        </li>
      </rulesRaw>
    </rulePack>
  </RulePackDef>
  
  <RulePackDef>
    <defName>NamerFactionEgypt</defName>
    <rulePack>
      <rulesStrings>
        <li>name->Kemet</li>
        <li>name->Aegyptus</li>
        <li>name->Pharaonic Empire</li>
        <li>name->Black Lands</li>
        <li>name->Egypt</li>
        <li>name->Ju Ahet</li>
        <li>name->Ptolomey Land</li>
        <li>name->Thirty-Fifth Dynasty of Egypt</li>
      </rulesStrings>
    </rulePack>
  </RulePackDef>
  
  <RulePackDef>
    <defName>NamerFactionEgyptReference</defName>
	<include>
		<li>NamerFactionEgypt</li>
	</include>
    <rulePack>
      <rulesStrings>
        <li>NamerFactionEgypt->Kemet</li>
        <li>NamerFactionEgypt->Aegyptus</li>
        <li>NamerFactionEgypt->the Pharaonic Empire</li>
        <li>NamerFactionEgypt->the Black Lands</li>
        <li>NamerFactionEgypt->Egypt</li>
        <li>NamerFactionEgypt->Ju Ahet</li>
        <li>NamerFactionEgypt->Ptolomey Land</li>
        <li>NamerFactionEgypt->the Thirty-Fifth Dynasty of Egypt</li>
		<li>NamerFactionEgypt->Ancient Egypt</li>
		<li>NamerFactionEgypt(p=0.05)-> Jerry's Domain</li>
      </rulesStrings>
    </rulePack>
  </RulePackDef>
</Defs>
